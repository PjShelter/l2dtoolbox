{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live2D Toolbox",
  "version": "0.1.0",
  "identifier": "com.codex.l2dtoolbox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Live2D Toolbox",
        "width": 1480,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 780
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
