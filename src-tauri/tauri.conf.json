{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live2D Toolbox",
  "version": "0.1.1",
  "identifier": "com.codex.l2dtoolbox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Live2D Toolbox",
        "width": 1180,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 940
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "signingIdentity": "-"
    }
  }
}
